<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:cyber="http://www.CAVFL019.org/ciberseguridad#">

  <!-- Clases -->
  <owl:Class rdf:about="http://www.CAVFL019.org/ciberseguridad#Amenaza"/>
  <owl:Class rdf:about="http://www.CAVFL019.org/ciberseguridad#Control"/>
  <owl:Class rdf:about="http://www.CAVFL019.org/ciberseguridad#Activo"/>

  <!-- Propiedades -->
  <owl:ObjectProperty rdf:about="http://www.CAVFL019.org/ciberseguridad#mitiga">
    <rdfs:domain rdf:resource="http://www.CAVFL019.org/ciberseguridad#Control"/>
    <rdfs:range rdf:resource="http://www.CAVFL019.org/ciberseguridad#Amenaza"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://www.CAVFL019.org/ciberseguridad#afecta">
    <rdfs:domain rdf:resource="http://www.CAVFL019.org/ciberseguridad#Amenaza"/>
    <rdfs:range rdf:resource="http://www.CAVFL019.org/ciberseguridad#Activo"/>
  </owl:ObjectProperty>

  <!-- Amenazas -->
  <owl:NamedIndividual rdf:about="http://www.CAVFL019.org/ciberseguridad#Phishing">
    <rdf:type rdf:resource="http://www.CAVFL019.org/ciberseguridad#Amenaza"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.CAVFL019.org/ciberseguridad#Malware">
    <rdf:type rdf:resource="http://www.CAVFL019.org/ciberseguridad#Amenaza"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.CAVFL019.org/ciberseguridad#Ransomware">
    <rdf:type rdf:resource="http://www.CAVFL019.org/ciberseguridad#Amenaza"/>
  </owl:NamedIndividual>

  <!-- Controles -->
  <owl:NamedIndividual rdf:about="http://www.CAVFL019.org/ciberseguridad#Firewall">
    <rdf:type rdf:resource="http://www.CAVFL019.org/ciberseguridad#Control"/>
    <cyber:mitiga rdf:resource="http://www.CAVFL019.org/ciberseguridad#Malware"/>
    <cyber:mitiga rdf:resource="http://www.CAVFL019.org/ciberseguridad#Ransomware"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.CAVFL019.org/ciberseguridad#AutenticacionDobleFactor">
    <rdf:type rdf:resource="http://www.CAVFL019.org/ciberseguridad#Control"/>
    <cyber:mitiga rdf:resource="http://www.CAVFL019.org/ciberseguridad#Phishing"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.CAVFL019.org/ciberseguridad#Antivirus">
    <rdf:type rdf:resource="http://www.CAVFL019.org/ciberseguridad#Control"/>
    <cyber:mitiga rdf:resource="http://www.CAVFL019.org/ciberseguridad#Malware"/>
    <cyber:mitiga rdf:resource="http://www.CAVFL019.org/ciberseguridad#Ransomware"/>
  </owl:NamedIndividual>

  <!-- Activos -->
  <owl:NamedIndividual rdf:about="http://www.CAVFL019.org/ciberseguridad#BaseDeDatos">
    <rdf:type rdf:resource="http://www.CAVFL019.org/ciberseguridad#Activo"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://www.CAVFL019.org/ciberseguridad#ServidorWeb">
    <rdf:type rdf:resource="http://www.CAVFL019.org/ciberseguridad#Activo"/>
  </owl:NamedIndividual>

</rdf:RDF>
